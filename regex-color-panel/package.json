{
  "name": "regex-color-panel",
  "displayName": "RegEx Color Panel",
  "description": "Inline color swatches and picker for any color format — hex, decimal, or float. Configure the regex pattern, channel order, value types, and output template per language.",
  "version": "0.0.1",
  "icon": "icon.png",
  "publisher": "sollapse",
  "license": "MIT",
  "keywords": ["color", "hex", "argb", "rgba", "bgr", "picker", "swatch"],
  "categories": ["Other", "Visualization"],
  "repository": { "type": "git", "url": "https://github.com/sollapse/AIGenDTools", "directory": "regex-color-panel" },
  "engines": { "vscode": "^1.75.0" },
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "RegEx Color Panel",
      "properties": {
        "regexColorPanel.formats": {
          "type": "array",
          "markdownDescription": "Color formats to recognize. Each entry specifies a regex `pattern` with one capture group per channel, a `channels` string mapping groups to `A`/`R`/`G`/`B`, an optional `channelTypes` string (`h`=hex, `d`=decimal 0-255, `f`=float 0.0-1.0), and a `template` that reconstructs the literal on color pick.\n\n**Example** \u2013 CSS rgba: `{ \"pattern\": \"rgba\\\\(\\\\s*(\\\\d{1,3})…\", \"channels\": \"RGBA\", \"channelTypes\": \"dddf\", \"template\": \"rgba({Rd}, {Gd}, {Bd}, {Af})\" }`",
          "items": {
            "type": "object",
            "required": ["pattern", "channels", "template"],
            "properties": {
              "name": {
                "type": "string",
                "description": "Human-readable label (for documentation only)."
              },
              "pattern": {
                "type": "string",
                "description": "Regex string. Each capture group must capture exactly 2 hex digits for one channel."
              },
              "channels": {
                "type": "string",
                "description": "Channel order of the capture groups, e.g. \"ARGB\", \"RGBA\", \"RGB\". Missing channels default to 255 (fully opaque)."
              },
              "channelTypes": {
                "type": "string",
                "description": "Value type per capture group — same length as 'channels'. Each char: 'h' = hex 2-digit (default), 'd' = decimal 0-255, 'f' = float 0.0-1.0. E.g. \"ddd\" for rgb(), \"dddf\" for rgba()."
              },
              "template": {
                "type": "string",
                "description": "Output template when the user picks a new color. {X} or {Xh} = hex, {Xd} = decimal (0-255), {Xf} = float (0.0-1.0), where X is A, R, G, or B. E.g. \"0x{A}{R}{G}{B}\", \"rgb({Rd}, {Gd}, {Bd})\", \"rgba({Rd}, {Gd}, {Bd}, {Af})\"."
              },
              "languages": {
                "type": "array",
                "items": { "type": "string" },
                "description": "VS Code language IDs this format applies to. Empty array or omitted = all languages."
              }
            }
          },
          "default": [
            {
              "name": "ARGB 32-bit",
              "pattern": "0x([0-9a-fA-F]{2})([0-9a-fA-F]{2})([0-9a-fA-F]{2})([0-9a-fA-F]{2})",
              "channels": "ARGB",
              "template": "0x{A}{R}{G}{B}",
              "languages": ["c", "cpp", "java", "kotlin", "objc", "swift"]
            },
            {
              "name": "RGB 24-bit",
              "pattern": "0x([0-9a-fA-F]{2})([0-9a-fA-F]{2})([0-9a-fA-F]{2})(?![0-9a-fA-F])",
              "channels": "RGB",
              "template": "0x{R}{G}{B}",
              "languages": ["c", "cpp", "java", "kotlin", "objc", "swift"]
            },
            {
              "name": "CSS / HTML RGBA 32-bit (#RRGGBBAA)",
              "pattern": "#([0-9a-fA-F]{2})([0-9a-fA-F]{2})([0-9a-fA-F]{2})([0-9a-fA-F]{2})(?![0-9a-fA-F])",
              "channels": "RGBA",
              "template": "#{R}{G}{B}{A}",
              "languages": []
            },
            {
              "name": "Win32 BGR COLORREF (0x00BBGGRR)",
              "pattern": "0x00([0-9a-fA-F]{2})([0-9a-fA-F]{2})([0-9a-fA-F]{2})",
              "channels": "BGR",
              "template": "0x00{B}{G}{R}",
              "languages": ["c", "cpp"]
            },
            {
              "name": "GLSL packed RGBA (0xRRGGBBAAu)",
              "pattern": "0x([0-9a-fA-F]{2})([0-9a-fA-F]{2})([0-9a-fA-F]{2})([0-9a-fA-F]{2})u",
              "channels": "RGBA",
              "template": "0x{R}{G}{B}{A}u",
              "languages": ["glsl", "cpp"]
            },
            {
              "name": "CSS rgb(r, g, b)",
              "pattern": "rgb\\(\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*\\)",
              "channels": "RGB",
              "channelTypes": "ddd",
              "template": "rgb({Rd}, {Gd}, {Bd})",
              "languages": ["css", "scss", "less", "html", "javascript", "typescript", "javascriptreact", "typescriptreact"]
            },
            {
              "name": "CSS rgba(r, g, b, a)",
              "pattern": "rgba\\(\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d{1,3})\\s*,\\s*(\\d*\\.?\\d+)\\s*\\)",
              "channels": "RGBA",
              "channelTypes": "dddf",
              "template": "rgba({Rd}, {Gd}, {Bd}, {Af})",
              "languages": ["css", "scss", "less", "html", "javascript", "typescript", "javascriptreact", "typescriptreact"]
            }
          ]
        }
      }
    }
  }
}
